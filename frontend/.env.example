# Локально: по умолчанию ws://localhost:8765
# Vercel / прод: обязательно — полный wss:// до WebSocket бота (на Vercel только статика, бота там нет).
# Пример: wss://your-bot-host.example.com:8765
# Без VITE_WS_URL в браузере будет localhost → с сайта vercel.app баланс никогда не появится.
VITE_WS_URL=
VITE_WS_PORT=8765
