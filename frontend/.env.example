# Куда подключаться по WebSocket (бот слушает WS_PORT, по умолчанию 8765).
#
# Локальная разработка: в репозитории уже есть .env.development с ws://localhost:8765
# (подхватывается при `npm run dev`). Можно не создавать свой .env.
#
# Бот на VPS, а Vite на Mac/ПК — укажите IP или домен VPS:
#   VITE_WS_URL=ws://203.0.113.10:8765
#
# Сайт на HTTPS (Vercel) — нужен wss:// за прокси с TLS.
VITE_WS_URL=
VITE_WS_PORT=8765
