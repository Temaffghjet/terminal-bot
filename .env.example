# Опционально, если exchange.name не binance/bybit — можно оставить пустым
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Hyperliquid (ccxt): WALLET_ADDRESS — основной кошелёк (маржа USDC на перпах).
# Можно указать и при симуляции: тогда fetch_positions работает без ворнинга. Реальные ордера
# включаются только config: ema_scalper.dry_run: false (и при необходимости PRIVATE_KEY).
# PRIVATE_KEY — API-агент Hyperliquid; не путать с адресом мастер-кошелька.
HYPERLIQUID_WALLET_ADDRESS=0x_your_master_wallet_with_balance
HYPERLIQUID_PRIVATE_KEY=0x_your_api_wallet_private_key

# Порт WebSocket UI (только число). Переменные VITE_* не сюда — они в frontend/.env
WS_PORT=8765
