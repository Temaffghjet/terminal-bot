# Опционально, если exchange.name не binance/bybit — можно оставить пустым
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Hyperliquid (ccxt): WALLET_ADDRESS — основной кошелёк, где маржа (USDC на перпах).
# PRIVATE_KEY — ключ API-кошелька (агента), привязанного к этому аккаунту в Hyperliquid, не путать адреса.
HYPERLIQUID_WALLET_ADDRESS=0x_your_master_wallet_with_balance
HYPERLIQUID_PRIVATE_KEY=0x_your_api_wallet_private_key
WS_PORT=8765
